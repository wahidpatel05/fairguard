# =============================================================================
# FairGuard – backend environment variables
# Copy this file to .env and fill in the values.  NEVER commit .env.
# =============================================================================

# ---------------------------------------------------------------------------
# Security – JWT
# ---------------------------------------------------------------------------
# Long random string used to sign JWT tokens.  Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret-key

# JWT algorithm (only HS256 supported out of the box)
ALGORITHM=HS256

# Token lifetime in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# asyncpg connection string for PostgreSQL 15
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://fairguard:fairguard@postgres:5432/fairguard

# ---------------------------------------------------------------------------
# Redis / Celery
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------------------------------------------------------------------------
# Ed25519 signing key
# ---------------------------------------------------------------------------
# Path (inside the container) to the PEM-encoded Ed25519 private key used to
# sign fairness receipts.  Generate a key pair with:
#   openssl genpkey -algorithm ed25519 -out /app/keys/ed25519_private.pem
SIGNING_KEY_PATH=/app/keys/ed25519_private.pem

# ---------------------------------------------------------------------------
# SMTP (for email notifications)
# ---------------------------------------------------------------------------
# Leave SMTP_HOST empty to disable email sending.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@fairguard.local

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins for the frontend.
# JSON array syntax is also accepted by Pydantic settings.
CORS_ORIGINS=["http://localhost:3000"]

# ---------------------------------------------------------------------------
# Bootstrap admin account (created automatically on first startup)
# ---------------------------------------------------------------------------
FIRST_ADMIN_EMAIL=admin@fairguard.local
FIRST_ADMIN_PASSWORD=changeme
