# Copy this file to .env and fill in the values before running docker-compose.
# Never commit .env to version control.

# -----------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------

# JWT secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-minimum-32-chars-change-in-production

# JWT algorithm (keep HS256 unless you switch to RS256)
ALGORITHM=HS256

# Access token lifetime in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -----------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------

DATABASE_URL=postgresql+asyncpg://fairguard:fairguard@postgres:5432/fairguard

# -----------------------------------------------------------------------
# Redis / Celery
# -----------------------------------------------------------------------

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -----------------------------------------------------------------------
# Ed25519 receipt signing
# -----------------------------------------------------------------------

# Path to the Ed25519 private key PEM file (mounted as a Docker volume).
# Generate with: openssl genpkey -algorithm ed25519 -out ed25519_private.pem
SIGNING_KEY_PATH=/app/keys/ed25519_private.pem

# -----------------------------------------------------------------------
# SMTP (optional — leave blank to disable email alerts)
# -----------------------------------------------------------------------

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@fairguard.local

# -----------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------

# JSON array of allowed origins (add your frontend URL in production)
CORS_ORIGINS=["http://localhost:3000","http://localhost:80","http://localhost"]

# -----------------------------------------------------------------------
# First admin account (seeded on first startup)
# -----------------------------------------------------------------------

FIRST_ADMIN_EMAIL=admin@fairguard.local
FIRST_ADMIN_PASSWORD=changeme123

