# Copy this file to .env and fill in the values before running docker-compose.
# Never commit .env to version control.

# PostgreSQL connection string used by the backend service.
DATABASE_URL=postgresql+asyncpg://fairguard:fairguard@postgres:5432/fairguard

# Redis connection string used for caching and task queues.
REDIS_URL=redis://redis:6379

# Django/FastAPI secret key — change this to a long random string in production.
SECRET_KEY=your-secret-key-change-in-production

# Ed25519 / RSA keys used to sign audit receipts (PEM-encoded, base64 optional).
# Leave blank to disable receipt signing.
SIGNING_PRIVATE_KEY=
SIGNING_PUBLIC_KEY=
